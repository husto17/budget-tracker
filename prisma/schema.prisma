generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Household {
  id        String            @id @default(cuid())
  createdAt DateTime          @default(now())
  members   User[]
  invites   HouseholdInvite[]
  categories      Category[]      @relation("HouseholdCategories")
  categoryRules   CategoryRule[]  @relation("HouseholdCategoryRules")
  merchantAliases MerchantAlias[] @relation("HouseholdMerchantAliases")
  goals           Goal[]          @relation("HouseholdGoals")
  tags            Tag[]           @relation("HouseholdTags")
  reimbursements  Reimbursement[] @relation("HouseholdReimbursements")
}

model HouseholdInvite {
  id           String    @id @default(cuid())
  householdId  String
  household    Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  invitedEmail String
  token        String    @unique @default(cuid())
  createdAt    DateTime  @default(now())
  expiresAt    DateTime

  @@index([token])
  @@index([invitedEmail])
}

model User {
  id             String          @id @default(cuid())
  email          String          @unique
  name           String
  password       String?
  image          String?
  createdAt      DateTime        @default(now())
  householdId    String?
  household      Household?      @relation(fields: [householdId], references: [id])
  accounts        Account[]
  categories      Category[]
  categoryRules   CategoryRule[]
  tags            Tag[]
  uploads         Upload[]
  merchantAliases MerchantAlias[]
  goals           Goal[]
  reimbursements  Reimbursement[]
}

model Goal {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  householdId   String?
  household     Household? @relation("HouseholdGoals", fields: [householdId], references: [id])
  name          String
  targetAmount  Float
  currentAmount Float     @default(0)
  targetDate    DateTime?
  color         String    @default("#6366F1")
  icon          String?
  linkedAccountId String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([userId])
  @@index([householdId])
  @@index([linkedAccountId])
}

model Account {
  id           String        @id @default(cuid())
  userId       String
  user         User          @relation(fields: [userId], references: [id])
  name         String
  type         String         // CHECKING, SAVINGS, CREDIT_CARD, CASH, INVESTMENT, OTHER
  institution  String?
  lastFour     String?
  isJoint      Boolean       @default(false)
  // Optional opening-balance anchor. If the user started importing statements
  // mid-life (e.g. only the last 6 months), they can set an anchor so the
  // computed balance starts from this value instead of $0 at the first import.
  openingBalance     Float?
  openingBalanceDate DateTime?
  createdAt    DateTime      @default(now())
  transactions Transaction[]
  uploads      Upload[]

  @@index([userId])
}

model Category {
  id            String          @id @default(cuid())
  userId        String
  user          User            @relation(fields: [userId], references: [id])
  name          String
  color         String          @default("#6B7280")
  icon          String?
  monthlyBudget  Float?
  budgetRollover Boolean         @default(false)
  isDefault      Boolean         @default(false)
  createdAt     DateTime        @default(now())
  householdId   String?
  household     Household?      @relation("HouseholdCategories", fields: [householdId], references: [id])
  transactions  Transaction[]
  rules         CategoryRule[]
  splits        TransactionSplit[]

  @@unique([userId, name])
  @@index([userId])
  @@index([householdId])
}

model CategoryRule {
  id          String     @id @default(cuid())
  userId      String
  user        User       @relation(fields: [userId], references: [id])
  categoryId  String
  category    Category   @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  pattern     String
  isRegex     Boolean    @default(false)
  priority    Int        @default(0)
  createdAt   DateTime   @default(now())
  householdId String?
  household   Household? @relation("HouseholdCategoryRules", fields: [householdId], references: [id])

  @@index([userId])
  @@index([householdId])
}

model Transaction {
  id                  String    @id @default(cuid())
  accountId           String
  account             Account   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  date                DateTime
  description         String
  originalDescription String
  amount              Float
  categoryId          String?
  category            Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  isCredit            Boolean   @default(false)
  notes               String?
  hash                String
  uploadId            String?
  upload              Upload?   @relation(fields: [uploadId], references: [id])
  // On joint accounts, whose expense was this really? Null means "shared /
  // unspecified" (the default). Set to me/partner to attribute a specific
  // transaction on a shared card/account to one person.
  payerUserId         String?

  // Transfer linking — pairs transactions across accounts
  transferPairId      String?
  transferPair        Transaction?  @relation("TransferPair", fields: [transferPairId], references: [id])
  transferPairOf      Transaction[] @relation("TransferPair")

  // Merchant normalization
  merchant            String?

  // Recurring detection
  isRecurring         Boolean   @default(false)
  recurringGroupId    String?
  // Manual override: "subscription" | "bill" | "none" | null (auto-detect)
  recurringType       String?

  // Screenshot / pending / reconciliation
  isPending           Boolean   @default(false)
  isReconciled        Boolean   @default(false)
  source              String    @default("statement")

  // Exclude from budget/spending math without deleting
  isExcluded          Boolean   @default(false)

  splits              TransactionSplit[]
  tags                TransactionTag[]

  // Reimbursements — many-to-many via Reimbursement join model.
  // Back-references allow computing net spending per tx.
  reimbursementsReceived Reimbursement[] @relation("ReimbursementOriginal")
  reimbursementsApplied  Reimbursement[] @relation("ReimbursementCredit")

  deletedAt           DateTime?

  createdAt           DateTime  @default(now())

  @@unique([accountId, hash])
  @@index([accountId])
  @@index([categoryId])
  @@index([date])
  @@index([transferPairId])
  @@index([merchant])
  @@index([recurringGroupId])
}

// Tracks shared expenses — you paid for something and others owe you back.
// reimbursementTxId is optional: set if/when the money comes back through the bank,
// otherwise mark settled manually. settled=true means you've been paid back.
model Reimbursement {
  id                String       @id @default(cuid())
  userId            String
  user              User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  householdId       String?
  household         Household?   @relation("HouseholdReimbursements", fields: [householdId], references: [id], onDelete: SetNull)

  originalTxId      String
  originalTx        Transaction  @relation("ReimbursementOriginal", fields: [originalTxId], references: [id], onDelete: Cascade)

  reimbursementTxId String?
  reimbursementTx   Transaction? @relation("ReimbursementCredit", fields: [reimbursementTxId], references: [id], onDelete: SetNull)

  amount            Float        // how much is owed back
  personName        String?      // who owes you, e.g. "Josh"
  note              String?      // e.g. "dinner"
  settled           Boolean      @default(false)
  settledAt         DateTime?
  createdAt         DateTime     @default(now())

  @@index([userId])
  @@index([householdId])
  @@index([originalTxId])
  @@index([reimbursementTxId])
}

model TransactionSplit {
  id            String      @id @default(cuid())
  transactionId String
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  categoryId    String?
  category      Category?   @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  amount        Float
  note          String?
  createdAt     DateTime    @default(now())

  @@index([transactionId])
}

model MerchantAlias {
  id          String     @id @default(cuid())
  userId      String
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  fromName    String     // what hardcoded normalization produces
  toName      String     // what user wants it to be
  createdAt   DateTime   @default(now())
  householdId String?
  household   Household? @relation("HouseholdMerchantAliases", fields: [householdId], references: [id])

  @@unique([userId, fromName])
  @@index([userId])
  @@index([householdId])
}

model Upload {
  id           String        @id @default(cuid())
  userId       String
  user         User          @relation(fields: [userId], references: [id])
  accountId    String
  account      Account       @relation(fields: [accountId], references: [id], onDelete: Cascade)
  fileName     String
  fileType     String
  rowCount     Int
  // Statement-level context captured during parse (when available).
  // Used to show reconciliation warnings: if the latest statement's
  // closingBalance + tx since statementEnd doesn't match the computed
  // balance, the Account card flags a divergence.
  openingBalance Float?
  closingBalance Float?
  statementStart DateTime?
  statementEnd   DateTime?
  createdAt    DateTime      @default(now())
  transactions Transaction[]

  @@index([userId])
  @@index([accountId])
}

model Tag {
  id           String           @id @default(cuid())
  userId       String
  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  householdId  String?
  household    Household?       @relation("HouseholdTags", fields: [householdId], references: [id])
  name         String
  color        String           @default("#6366f1")
  createdAt    DateTime         @default(now())
  transactions TransactionTag[]

  @@unique([userId, name])
  @@index([userId])
  @@index([householdId])
}

model TransactionTag {
  transactionId String
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  tagId         String
  tag           Tag         @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([transactionId, tagId])
  @@index([tagId])
}
